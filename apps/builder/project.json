{
  "name": "builder-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "targets": {
    "dev": {
      "dependsOn": [
        { "projects": ["@msheet/builder"], "target": "build:css:watch" },
        { "projects": ["@msheet/fields"], "target": "build:css:watch" },
        { "projects": ["@msheet/renderer"], "target": "build:css:watch" }
      ],
      "executor": "nx:run-commands",
      "options": {
        "command": "npx nx run builder-app:serve"
      }
    },
    "serve": {
      "dependsOn": [
        { "projects": ["@msheet/builder"], "target": "build:css" },
        { "projects": ["@msheet/fields"], "target": "build:css" },
        { "projects": ["@msheet/renderer"], "target": "build:css" }
      ]
    }
  }
}
