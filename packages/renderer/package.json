{
  "name": "@msheet/renderer",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@msheet/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build:css": "cd ../.. && npx @tailwindcss/cli -i packages/renderer/src/index.css -o packages/renderer/src/index.output.css",
    "build:css:watch": "cd ../.. && npx @tailwindcss/cli -i packages/renderer/src/index.css -o packages/renderer/src/index.output.css --watch"
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "nx": {
    "tags": [
      "scope:renderer"
    ]
  },
  "dependencies": {
    "@msheet/core": "^0.0.1",
    "@msheet/fields": "^0.0.1",
    "js-yaml": "^4.1.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "tailwindcss": "^4.2.1"
  }
}
